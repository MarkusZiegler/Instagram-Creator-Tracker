# Database (absolute path for Railway volume, relative for local dev)
DATABASE_URL=sqlite:///./data/insta_tracker.db

# Security
SECRET_KEY=change-me-generate-with-python3-c-import-secrets-print-secrets-token-hex-32

# Instagram credentials (strongly recommended - use a secondary/throwaway account)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_FILE=./data/ig_session

# Email notifications (Gmail SMTP with App Password)
# Enable 2FA on Gmail, then: Google Account → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
NOTIFY_EMAIL=where-to-send@email.com

# Scheduler
MORNING_CHECK_HOUR=7
MORNING_CHECK_MINUTE=0
TIMEZONE=Europe/Vienna

# Rate limiting (seconds between creator checks)
DELAY_BETWEEN_CREATORS_MIN=3.0
DELAY_BETWEEN_CREATORS_MAX=8.0
MAX_POSTS_PER_CREATOR_PER_CHECK=12
